# ------------------------------
# Sistema de Control Académico EMI - ICI
# Archivo base para repositorio multiplataforma
# Compatible con backend Python/Django y frontend web React/Next
# ------------------------------

# === Sistema operativo ===
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# === Editores / IDE ===
.idea/
*.swp
*.swo
*~

# VS Code: se ignora casi todo, pero se permite compartir configuración útil del equipo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# === Variables de entorno y secretos ===
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# === Python ===
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
.venv/
venv/
env/
ENV/

# Empaquetado / builds Python
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Herramientas de calidad / pruebas Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Django / logs locales
*.log
logs/
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# === Node / React / Next ===
node_modules/
.next/
out/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Contenedores y artefactos locales ===
.docker/
docker-data/
*.pid

# === Reportes / resultados generados ===
exports/
artifacts/
playwright-report/
test-results/

# === Documentación generada ===
docs/_build/
docs/referencias_privadas/
site/

# === Temporales ===
tmp/
temp/
backups/
